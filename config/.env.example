# 智谱 AI 配置（GLM-4.6V 图片理解，必填）
ZHIPU_API_KEY=your_zhipu_api_key_here

# Qwen 兼容 API 配置（意图识别，必填）
NAU_API_KEY=your_nau_api_key_here
NAU_BASE_URL=https://your-qwen-api-base-url/v1

# 邮件监控配置
EMAIL_HOST=imap.qq.com
EMAIL_PORT=993
EMAIL_USER=your_email@qq.com
EMAIL_PASS=your_email_password_or_app_token

# 微信监控配置
WECHAT_FILE_PATH=C:\Users\{YOUR_USERNAME}\Documents\WeChat Files\{YOUR_WXID}\FileStorage

# 通知配置（配了哪个就用哪个，可叠加；至少配一个才能收到预警）
# --- 邮件通知（推荐）---
# SMTP 服务器自动从 EMAIL_HOST 推断（imap.qq.com → smtp.qq.com），也可手动覆盖
# SMTP_HOST=smtp.qq.com
SMTP_PORT=465
NOTIFY_TO_EMAIL=your_alert_recipient@example.com  # 预警发给谁

# --- 可选：飞书/钉钉 Webhook（有账号才填）---
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=

# 风险阈值配置
HIGH_RISK_THRESHOLD=0.8
MEDIUM_RISK_THRESHOLD=0.6
LOW_RISK_THRESHOLD=0.3

# 监护人联动（极高风险时额外通知，留空则不触发）
GUARDIAN_EMAIL=guardian@example.com   # 监护人邮件地址（推荐）
GUARDIAN_FEISHU=                       # 监护人飞书 Webhook（可选）

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=logs/

# 向量库配置
LANCEDB_PATH=cases/lancedb
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.65

# 自反思配置
REFLECTION_ENABLED=true
MEMORY_PATH=memory/
